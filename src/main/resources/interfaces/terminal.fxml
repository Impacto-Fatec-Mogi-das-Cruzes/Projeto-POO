<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="800.0" prefHeight="500.0"
            stylesheets="@terminal.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ui.controller.TerminalController"
            styleClass="game-root">

    <!-- ================= TOP HUD BAR ================= -->
    <top>
        <HBox styleClass="hud-bar">
            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>

            <children>
                <Label text="AlfaBash v1.0"
                    styleClass="hud-title"
                    HBox.hgrow="ALWAYS"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="✕"
                        styleClass="hud-close-button"
                        onAction="#exitGame"/>
            </children>
        </HBox>
    </top>

    <!-- ===================== -->
    <!-- CENTER FRAME -->
    <!-- ===================== -->
    <center>
        <StackPane styleClass="game-frame">

            <ScrollPane fx:id="scrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        styleClass="game-scroll">

                <content>
                    <VBox fx:id="outputArea"
                          styleClass="game-output"
                          spacing="6"/>
                </content>

            </ScrollPane>

        </StackPane>
    </center>

    <!-- ===================== -->
    <!-- COMMAND BAR -->
    <!-- ===================== -->
    <bottom>
        <HBox styleClass="command-bar">

            <Label text=">"
                   styleClass="command-label"/>

            <TextField fx:id="inputField"
                       HBox.hgrow="ALWAYS"
                       styleClass="command-input"
                       onAction="#commandEntered"/>

        </HBox>
    </bottom>

</BorderPane>