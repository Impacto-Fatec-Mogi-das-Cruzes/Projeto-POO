<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768" prefWidth="1024" styleClass="root-pane" stylesheets="@retro_terminal.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ui.controller.MainTerminalController">

    <!-- ═══════════════════════════════════════════════════
         BARRA SUPERIOR — STATUS DO SISTEMA
    ═══════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="status-bar-top">

            <!-- Bloco: Nome do sistema -->
            <HBox alignment="CENTER" styleClass="status-block">
                <Label styleClass="status-system-name" text="FORENSYS v2.1.4" />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Bloco: Status da conexão -->
            <HBox alignment="CENTER" spacing="6" styleClass="status-block">
                <Label fx:id="statusIndicator" styleClass="status-dot-online" text="●" />
                <Label fx:id="statusLabel" styleClass="status-text" text="CONECTADO" />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Bloco: Caso ativo -->
            <HBox alignment="CENTER" spacing="6" styleClass="status-block">
                <Label styleClass="status-label-dim" text="CASO:" />
                <Label fx:id="caseIdLabel" styleClass="status-case-id" text="INV-1994-0047" />
            </HBox>

            <!-- Espaçador -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Bloco: Usuário -->
            <HBox alignment="CENTER" spacing="6" styleClass="status-block">
                <Label styleClass="status-label-dim" text="USR:" />
                <Label fx:id="userLabel" styleClass="status-text" text="DET.SOUZA" />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Bloco: Relógio -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block">
                <Label fx:id="clockLabel" styleClass="status-clock" text="23:47:03" />
            </HBox>

        </HBox>
    </top>
    
    <center>
        <VBox styleClass="terminal-panel">

            <!-- Cabeçalho do terminal -->
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="terminal-header">
                <Label styleClass="header-bracket" text="[" />
                <Label styleClass="panel-header-text" text="TERMINAL FORENSE" />
                <Label styleClass="header-bracket" text="]" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="terminalStatusLabel" styleClass="terminal-status-ready" text="PRONTO" />
                <Label styleClass="status-separator" text="│" />
                <Label fx:id="commandCountLabel" styleClass="status-label-dim" text="CMD: 0" />
            </HBox>

            <!-- Área de saída do terminal — Scroll -->
            <ScrollPane fx:id="terminalScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="terminal-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

                <VBox fx:id="terminalOutput" spacing="1" styleClass="terminal-output-box" />

            </ScrollPane>

            <!-- Linha divisória animada -->
            <HBox alignment="CENTER" styleClass="terminal-divider">
                <Label fx:id="scanlineLabel" styleClass="scanline-bar" text="────────────────────────────────────────────────────────────────────" />
            </HBox>

            <!-- Área de entrada de comandos -->
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="command-input-area">

                <!-- Prompt do usuário -->
                <Label fx:id="promptLabel" styleClass="command-prompt" text="DET.SOUZA@FORENSYS:~$ " />

                <!-- Campo de texto -->
                <TextField fx:id="commandInput" onAction="#onCommandEntered" promptText="digite um comando..." styleClass="command-textfield" HBox.hgrow="ALWAYS" />

                <!-- Cursor simulado (visual) -->
                <Label fx:id="cursorLabel" styleClass="cursor-blink" text="█" />

            </HBox>

        </VBox>
    </center>

    <!-- ═══════════════════════════════════════════════════
         BARRA INFERIOR — INFORMAÇÕES DO SISTEMA
    ═══════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="status-bar-bottom">

            <!-- Memória -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block-sm">
                <Label styleClass="status-label-dim" text="MEM:" />
                <Label fx:id="memoryLabel" styleClass="status-text" text="2.1MB/4MB" />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Disco -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block-sm">
                <Label styleClass="status-label-dim" text="DISCO:" />
                <Label fx:id="diskLabel" styleClass="status-text" text="C: 127MB livre" />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Modo atual -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block-sm">
                <Label styleClass="status-label-dim" text="MODO:" />
                <Label fx:id="modeLabel" styleClass="status-text-highlight" text="INVESTIGAÇÃO" />
            </HBox>

            <!-- Espaçador -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Mensagem de sistema / alerta -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block-sm">
                <Label fx:id="systemMessageLabel" styleClass="status-message" text="Sistema operando normalmente." />
            </HBox>

            <Label styleClass="status-separator" text="│" />

            <!-- Contador de erros -->
            <HBox alignment="CENTER" spacing="4" styleClass="status-block-sm">
                <Label styleClass="status-label-dim" text="ERR:" />
                <Label fx:id="errorCountLabel" styleClass="status-text" text="0" />
            </HBox>

        </HBox>
    </bottom>

</BorderPane>
