<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@messager.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.forensys.ui.controller.MessagerController"
            styleClass="game-root">

    <!-- ================= TOP HUD BAR ================= -->
    <top>
        <HBox styleClass="hud-topbar" spacing="10">
            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>

            <children>
                <Label text="AlfaTalk v1.0"
                       styleClass="hud-title"
                       HBox.hgrow="ALWAYS"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="✕"
                        styleClass="hud-close-btn"/>
            </children>
        </HBox>
    </top>

    <!-- ================= CENTER GAME AREA ================= -->
    <center>
        <BorderPane styleClass="game-center">

            <center>
                <SplitPane dividerPositions="0.30"
                           styleClass="game-split">

                    <!-- ===== CONTACTS ===== -->
                    <VBox styleClass="panel panel-left">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>

                        <children>
                            <Label text="[ CONTATOS ]"
                                   styleClass="panel-title"/>

                            <ListView fx:id="contactListView"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="game-list"/>
                        </children>
                    </VBox>

                    <!-- ===== CHAT ===== -->
                    <VBox styleClass="panel panel-right">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>

                        <children>
                            <Label fx:id="selectedContactLabel"
                                   text="[ CHAT ]"
                                   styleClass="panel-title"/>

                            <ListView fx:id="messagesListView"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="game-list"/>
                        </children>
                    </VBox>

                </SplitPane>
            </center>

        </BorderPane>
    </center>

    <!-- ================= BOTTOM STATUS BAR ================= -->
    <bottom>
        <HBox styleClass="hud-bottombar">
            <padding>
                <Insets top="6" right="10" bottom="6" left="10"/>
            </padding>

            <children>
                <Label text="TIP: 'q' para sair"
                       styleClass="hud-hint"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>